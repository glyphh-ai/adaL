# Ada Configuration
# Copy to .env (cp .env.example .env). Loaded by both the runtime server and
# the `ada` REPL. Secrets can also be stored encrypted in ~/.ada/vault
# (run: ada setup key).

# ── Model ─────────────────────────────────────────────────────────────
# ADA_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=sk-ant-...

# ── Server ────────────────────────────────────────────────────────────
# HOST=0.0.0.0
# PORT=8002

# ── Storage / Database ────────────────────────────────────────────────
# Default (unset): SQLite at ~/.ada/ada.db — zero setup, in-process.
#
# Set DATABASE_URL to a Postgres URL to switch Ada to the pgvector backend:
# persistent thought memory (encoded once, reconstructed on boot — no
# re-encoding) and HNSW cosine recall at scale. On first boot the runtime
# enables the vector extension and runs alembic migrations automatically.
#
# Local Postgres:
# DATABASE_URL=postgresql://ada:ada@localhost:5432/ada
#
# With `docker compose up` this is set for you (service name `db`):
# DATABASE_URL=postgresql://ada:ada@db:5432/ada

# ── docker compose overrides (optional) ───────────────────────────────
# POSTGRES_USER=ada
# POSTGRES_PASSWORD=ada
# POSTGRES_DB=ada
# POSTGRES_PORT=5432

# Require Bearer tokens on /mcp (recommended for any non-local deployment)
ADA_AUTH_REQUIRED=false
